// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Client {
  id                  String        @id @default(cuid())
  fullName            String
  email               String        @unique
  phone               String?
  profilePicture      String?
  bookingHistory      Appointment[]
  favoriteEstheticians Esthetician[] @relation("ClientFavorites")
  paymentCustomerId   String?
  referralsSent       Int           @default(0)
  loyaltyPoints       Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Esthetician {
  id                  String        @id @default(cuid())
  fullName            String
  profilePicture      String?
  description         String?
  services            Service[]
  latitude            Float
  longitude           Float
  email               String        @unique
  phone               String?
  availability        Json? // Simple for now
  portfolio           Json          @default("[]") // Stored as a JSON array of strings
  certifications      Json          @default("[]") // Stored as a JSON array of strings
  reviews             Review[]
  stripeAccountId     String?
  paypalAccountId     String?
  verified            Boolean       @default(false)
  travelToClient      Boolean       @default(false)
  serviceRadiusKm     Int?
  visible             Boolean       @default(true)
  cityTargeting       Json          @default("[]") // Stored as a JSON array of strings
  favoritedBy         Client[]      @relation("ClientFavorites")
  appointments        Appointment[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Service {
  id          String        @id @default(cuid())
  name        String
  description String
  price       Float
  esthetician Esthetician   @relation(fields: [estheticianId], references: [id])
  estheticianId String
  appointments Appointment[]
}

model Appointment {
  id            String            @id @default(cuid())
  client        Client            @relation(fields: [clientId], references: [id])
  clientId      String
  esthetician   Esthetician       @relation(fields: [estheticianId], references: [id])
  estheticianId String
  service       Service           @relation(fields: [serviceId], references: [id])
  serviceId     String
  dateTime      DateTime
  status        AppointmentStatus @default(PENDING)
  paymentStatus PaymentStatus     @default(UNPAID)
  notes         String?
  invoiceUrl    String?
  location      String // "IN_SALON" or "AT_HOME"
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Review {
  id            String      @id @default(cuid())
  rating        Int
  comment       String?
  esthetician   Esthetician @relation(fields: [estheticianId], references: [id])
  estheticianId String
  clientId      String
  createdAt     DateTime    @default(now())
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}
